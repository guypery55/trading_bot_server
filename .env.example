# ─────────────────────────────────────────────
# IBKR Connection
# ─────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_CONNECTION_TYPE=tws    # tws | gateway
# IBKR_PORT=7497            # Optional: auto-derived from TRADING_MODE if omitted
#                           # paper+tws=7497, paper+gateway=4002
#                           # live+tws=7496,  live+gateway=4001
IBKR_CLIENT_ID=1            # Must be unique if multiple scripts connect simultaneously

# ─────────────────────────────────────────────
# Trading Mode
# ─────────────────────────────────────────────
TRADING_MODE=paper          # paper | live

# ─────────────────────────────────────────────
# Strategy
# ─────────────────────────────────────────────
SYMBOL=AAPL
BAR_SIZE=5 mins             # IBKR bar size string (e.g. "1 min", "5 mins", "1 hour")
STRATEGY=rsi_macd           # rsi_macd | breakout

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ─────────────────────────────────────────────
# Notifications (optional)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
