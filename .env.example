# ─────────────────────────────────────────────
# IBKR Connection
# ─────────────────────────────────────────────
IBKR_HOST=127.0.0.1

# tws | gateway
IBKR_CONNECTION_TYPE=gateway

# Optional: auto-derived from TRADING_MODE + CONNECTION_TYPE if omitted
#   paper + tws = 7497    paper + gateway = 4002
#   live  + tws = 7496    live  + gateway = 4001
# IBKR_PORT=4002

# Must be unique if multiple scripts connect simultaneously
IBKR_CLIENT_ID=1

# ─────────────────────────────────────────────
# Trading Mode
# ─────────────────────────────────────────────
# paper | live
TRADING_MODE=paper

# ─────────────────────────────────────────────
# Strategy
# ─────────────────────────────────────────────
# rsi_macd | breakout | swing
STRATEGY=swing

# IBKR bar size string (e.g. "1 min", "5 mins", "1 hour")
BAR_SIZE=5 mins

# Comma-separated list of symbols to trade
SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,JNJ,V,UNH,XOM,PG,MA,HD,CVX,MRK,ABBV,LLY,PEP,KO,AVGO,COST,TMO,WMT,DIS,CSCO,ABT,MCD,ACN,NEE,NKE,INTC,VZ,TXN,CRM,QCOM,DHR,HON,LIN,AMGN,IBM,PM,CAT,GE,SBUX,AXP,BA,MMM,SPG

# ─────────────────────────────────────────────
# Risk Management
# ─────────────────────────────────────────────
# Maximum total dollar value of orders placed per day (across all symbols)
DAILY_SPEND_LIMIT=1000.00

# Halt all trading if today's realized P&L drops below this (negative = loss)
DAILY_LOSS_LIMIT=500.00

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# Notifications (optional)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
