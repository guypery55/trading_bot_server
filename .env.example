# Exchange API Keys
EXCHANGE=binance          # binance | bybit | kraken | coinbase
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=           # required for some exchanges (e.g. coinbase)

# Trading Mode
TRADING_MODE=paper        # paper | live
BASE_CURRENCY=USDT

# Server
PORT=8000
HOST=0.0.0.0

# Database
DATABASE_URL=sqlite:///./trading_bot.db

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
